# PostHog browser-side public key — injected in the client bundle (safe to expose).
POSTHOG_PUBLIC_KEY=phc_your_posthog_project_api_key

# PostHog project API key for server-side events (webhook handler). Same value
# as POSTHOG_PUBLIC_KEY in practice; we keep it as a separate env var for clarity
# and to allow rotating server-only credentials independently in the future.
POSTHOG_PROJECT_API_KEY=phc_your_posthog_project_api_key

# Lemon Squeezy webhook signing secret — used to verify the HMAC-SHA256
# signature on incoming order/subscription webhooks. Get it from:
# Lemon Squeezy admin → Settings → Webhooks → "Signing secret"
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_your_lemon_squeezy_signing_secret

# Optional: GitHub Personal Access Token used by /api/releases to lift the
# unauthenticated rate limit (60 req/h per IP) up to 5000 req/h. Only needed
# if you expect heavy traffic or run multiple Nitro instances behind the same
# IP. A read-only token with `public_repo` scope is enough.
# Without it, /api/releases falls back to anonymous calls (still works, just
# capped at 60/h shared across all your traffic).
# GITHUB_TOKEN=ghp_your_read_only_token
